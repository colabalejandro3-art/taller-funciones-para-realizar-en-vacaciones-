# 1. Promedio, nota más alta y más baja de una lista de notas
def estadisticas_notas(notas):
    """
    Recibe una lista de notas y retorna una tupla (promedio, max, min)
    """
    if not notas:
        return (0, 0, 0)
    promedio = sum(notas) / len(notas)
    max_nota = max(notas)
    min_nota = min(notas)
    return (promedio, max_nota, min_nota)

# 2. Estudiantes aprobados (nota >= 3.0) a partir de una lista de tuplas (nombre, nota)
def aprobados(estudiantes):
    """
    Filtra los estudiantes con nota >= 3.0 y retorna una lista de tuplas (nombre, nota)
    """
    return [(nombre, nota) for nombre, nota in estudiantes if nota >= 3.0]

# 3. Agenda simple: agregar, buscar y eliminar contactos (diccionario)
agenda = {}  # diccionario global para almacenar contactos

def agregar_contacto(nombre, telefono):
    agenda[nombre] = telefono

def buscar_contacto(nombre):
    return agenda.get(nombre, "Contacto no encontrado")

def eliminar_contacto(nombre):
    if nombre in agenda:
        del agenda[nombre]
        return True
    return False

# 4. Inventario: cada producto con nombre, precio y cantidad. Calcular valor total.
def valor_total_inventario(inventario):
    """
    inventario: lista de diccionarios con claves 'nombre', 'precio', 'cantidad'
    Retorna el valor total (suma de precio * cantidad)
    """
    total = 0
    for producto in inventario:
        total += producto['precio'] * producto['cantidad']
    return total

# 5. Frecuencia de palabras en una lista
def frecuencia_palabras(lista_palabras):
    """
    Construye un diccionario con la frecuencia de cada palabra
    """
    freq = {}
    for palabra in lista_palabras:
        freq[palabra] = freq.get(palabra, 0) + 1
    return freq

# 6. Temperaturas semanales por ciudad: encontrar la más caliente y la más fría de la semana
def temperaturas_extremas(temp_ciudades):
    """
    temp_ciudades: diccionario {ciudad: [lista de 7 temperaturas]}
    Retorna una tupla (ciudad_mas_caliente, temp_max, ciudad_mas_fria, temp_min)
    """
    todas_temp = []
    for ciudad, temps in temp_ciudades.items():
        for t in temps:
            todas_temp.append((ciudad, t))
    if not todas_temp:
        return (None, None, None, None)
    max_temp = max(todas_temp, key=lambda x: x[1])
    min_temp = min(todas_temp, key=lambda x: x[1])
    return (max_temp[0], max_temp[1], min_temp[0], min_temp[1])

# 7. Convertir notas numéricas a letras usando tuplas como rangos
# Rangos definidos como una lista de tuplas (limite_inferior, limite_superior, letra)
rangos_notas = [
    (90, 100, 'A'),
    (80, 89, 'B'),
    (70, 79, 'C'),
    (60, 69, 'D'),
    (0, 59, 'F')
]

def nota_a_letra(nota):
    for inf, sup, letra in rangos_notas:
        if inf <= nota <= sup:
            return letra
    return 'F'  # por si acaso

def reporte_estudiantes(estudiantes):
    """
    estudiantes: lista de tuplas (nombre, nota)
    Retorna una lista de tuplas (nombre, letra)
    """
    return [(nombre, nota_a_letra(nota)) for nombre, nota in estudiantes]

# 8. Carrito de compras: agregar productos, aplicar descuentos, total a pagar
carrito = []  # lista de diccionarios {'producto': str, 'precio': float, 'cantidad': int}

def agregar_producto(producto, precio, cantidad=1):
    carrito.append({'producto': producto, 'precio': precio, 'cantidad': cantidad})

def aplicar_descuento(porcentaje):
    """
    Aplica un descuento porcentual al total del carrito y retorna el total con descuento.
    No modifica el carrito.
    """
    total = sum(item['precio'] * item['cantidad'] for item in carrito)
    descuento = total * (porcentaje / 100)
    return total - descuento

def total_carrito():
    return sum(item['precio'] * item['cantidad'] for item in carrito)

# 9. Agrupar productos por categoría a partir de una lista de tuplas (producto, categoría)
def agrupar_por_categoria(productos):
    """
    productos: lista de tuplas (producto, categoria)
    Retorna un diccionario {categoria: [lista de productos]}
    """
    grupos = {}
    for prod, cat in productos:
        grupos.setdefault(cat, []).append(prod)
    return grupos

# 10. Registro de votos: detectar inválidos, determinar ganador y su porcentaje
def procesar_votos(votos, candidatos_validos):
    """
    votos: lista de strings (nombre del candidato votado)
    candidatos_validos: conjunto o lista de nombres válidos
    Retorna un diccionario con el resumen y el ganador.
    """
    conteo = {}
    invalidos = 0
    for voto in votos:
        if voto in candidatos_validos:
            conteo[voto] = conteo.get(voto, 0) + 1
        else:
            invalidos += 1
    total_validos = sum(conteo.values())
    if total_validos == 0:
        return None  # No hay votos válidos
    # Encontrar ganador
    ganador = max(conteo.items(), key=lambda x: x[1])
    porcentaje = (ganador[1] / total_validos) * 100
    return {
        'conteo': conteo,
        'votos_invalidos': invalidos,
        'ganador': ganador[0],
        'porcentaje_ganador': porcentaje
    }

